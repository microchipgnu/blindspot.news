---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Structured judgment for things that are hard to think about." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — PhilOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen">
    <header class="border-b border-[var(--color-border)] px-6 py-4">
      <nav class="mx-auto flex max-w-5xl items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight">PhilOS</a>
        <div class="flex gap-6 text-sm text-[var(--color-text-muted)]">
          <a href="/" class="hover:text-[var(--color-text)]">Today</a>
          <a href="/archive" class="hover:text-[var(--color-text)]">Archive</a>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-5xl px-6 py-8">
      <slot />
    </main>
    <footer class="border-t border-[var(--color-border)] px-6 py-6 text-center text-xs text-[var(--color-text-dim)]">
      PhilOS — structured judgment for things that are hard to think about
    </footer>
  </body>
</html>
