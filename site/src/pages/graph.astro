---
import Base from "../layouts/Base.astro";
import { getAllTags, getAllActors } from "../lib/reports";

const tags = getAllTags();
const actors = getAllActors();
---

<Base title="Graph">
  <div class="py-10">
    <h1 class="font-serif text-4xl italic">Graph</h1>
    <p class="mt-2 text-[15px] text-[var(--color-text-secondary)]">Connections between briefs — shared topics, recurring actors, and who keeps paying.</p>

    <section class="mt-12">
      <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">Topics</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((t) => (
          <a
            href={`/topic/${t.slug}`}
            class="inline-flex items-baseline gap-1.5 rounded-full border border-[var(--color-border)] px-3 py-1 text-[13px] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
          >
            <span>{t.tag}</span>
            <span class="text-[11px] text-[var(--color-text-tertiary)]">{t.count}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">Who Pays — Recurring</h2>
      <p class="mt-2 text-[14px] text-[var(--color-text-tertiary)]">Actors who show up across multiple briefs.</p>
      <div class="mt-4 divide-y divide-[var(--color-border)]">
        {actors.filter((a) => a.appearances.length > 1).length === 0 ? (
          <p class="py-4 text-[14px] text-[var(--color-text-tertiary)]">No recurring actors yet — check back as more briefs accumulate.</p>
        ) : (
          actors.filter((a) => a.appearances.length > 1).map((a) => (
            <a
              href={`/actor/${a.slug}`}
              class="group block py-4 transition-colors hover:bg-[var(--color-surface-warm)]"
            >
              <div class="flex items-baseline justify-between">
                <span class="font-medium group-hover:text-[var(--color-accent)]">{a.name}</span>
                <span class="text-[12px] text-[var(--color-text-tertiary)]">{a.appearances.length} briefs</span>
              </div>
            </a>
          ))
        )}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">All Actors</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {actors.map((a) => (
          <a
            href={`/actor/${a.slug}`}
            class="inline-flex items-baseline gap-1.5 rounded-full border border-[var(--color-border)] px-3 py-1 text-[13px] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
          >
            <span>{a.name}</span>
            <span class="text-[11px] text-[var(--color-text-tertiary)]">{a.appearances.length}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>
