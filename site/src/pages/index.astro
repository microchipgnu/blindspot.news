---
import Base from "../layouts/Base.astro";
import DayView from "../components/DayView.astro";
import { getLatestDay, getDays } from "../lib/reports";

const day = getLatestDay();
const days = getDays();
const prevDate = days.length > 1 ? days[1] : null;
---

<Base title="Today">
  {!day ? (
    <p class="py-20 text-[var(--color-text-tertiary)]">No reports yet.</p>
  ) : (
    <DayView day={day} prevDate={prevDate} nextDate={null} />
  )}
</Base>
